<?xml version="1.0" encoding="UTF-8"?>
<!--
  dropQbsd — Thunar Custom Actions
  Place in: ~/.config/Thunar/uca.xml

  Adds right-click menu entries for:
    qimport — Import file from /home/drop into ~/Downloads
    qcp     — Copy file into /home/drop (original stays in place)
    qmv     — Move file into /home/drop (original is deleted)

  Requires: dropQbsd scripts installed in /usr/local/bin/dropQbsd/
-->
<actions>
<action>
	<icon>folder-download</icon>
	<name>qimport (Drop → Downloads)</name>
	<submenu>dropQbsd</submenu>
	<unique-id>1780153704581037-1</unique-id>
	<command>/usr/local/bin/dropQbsd/qimport %f</command>
	<description>Import from Drop to Downloads</description>
	<range>*</range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>folder-publicshare</icon>
	<name>qcp (Copy to Drop)</name>
	<submenu>dropQbsd</submenu>
	<unique-id>1780153802217419-2</unique-id>
	<command>/usr/local/bin/dropQbsd/qcp %f</command>
	<description>Copy to Drop (original stays in place)</description>
	<range>*</range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>stock_folder-move</icon>
	<name>qmv (Move to Drop)</name>
	<submenu>dropQbsd</submenu>
	<unique-id>1780153953429549-3</unique-id>
	<command>/usr/local/bin/dropQbsd/qmv %f</command>
	<description>Move to Drop (original is deleted)</description>
	<range>*</range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
</actions>
