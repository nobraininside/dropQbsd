#!/bin/ksh
# ==========================================================
#   dropQbsd -- pkg_add_via_pf
#
#  Installs or updates OpenBSD packages through the
#  restrictive PF ruleset. Populates the <updates> table
#  with mirror IPs, runs pkg_add, and leaves the table
#  populated (harmless on an isolated system).
#
#  Path: /opt/dropQbsd/admin/pkg_add_via_pf
#  Permissions: chmod 700, root:wheel
#
#  Usage: pkg_add_via_pf pkg1 [pkg2 ...]
#         pkg_add_via_pf -u          # update all packages
# ==========================================================

ENSURE_SCRIPT="/opt/dropQbsd/libexec/ensure_updates_table"
LOGFILE="/var/log/pkg_add_pf.log"

#-----------------------------------------------------------------------------
# LOG FUNCTION
#-----------------------------------------------------------------------------
log() {
	msg="$1"
	echo "$msg"
	echo "$(date '+%F %T')  $msg" >> "$LOGFILE"
}

#-----------------------------------------------------------------------------
# PRIVILEGE CHECK
#-----------------------------------------------------------------------------
if [ "$(id -u)" -ne 0 ]; then
	echo "Must run as root." >&2
	exit 2
fi

#-----------------------------------------------------------------------------
# USAGE CHECK
#-----------------------------------------------------------------------------
if [ $# -lt 1 ]; then
	echo "Usage: $0 pkg1 [pkg2 ...]  |  $0 -u" >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# DEPENDENCY CHECK
#-----------------------------------------------------------------------------
if [ ! -x "$ENSURE_SCRIPT" ]; then
	echo "FATAL: $ENSURE_SCRIPT not found or not executable." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# POPULATE PF TABLE
#-----------------------------------------------------------------------------
log "=== pkg_add_via_pf starting ==="
"$ENSURE_SCRIPT" || exit $?

#-----------------------------------------------------------------------------
# TRAP FOR GRACEFUL INTERRUPTION
#-----------------------------------------------------------------------------
cleanup() {
	log ""
	log "Interrupted (signal received)."
	log "The <updates> table is still  this is safe."
	log "To flush it manually: pfctl -t updates -T flush"
}
trap cleanup INT TERM

#-----------------------------------------------------------------------------
# RUN pkg_add
#-----------------------------------------------------------------------------
log "Running: pkg_add $*"
pkg_add "$@"
RC=$?

if [ $RC -eq 0 ]; then
	log "pkg_add completed successfully."
else
	log "pkg_add exited with code  check output above."
fi

log "=== pkg_add_via_pf finished ==="
exit $RC
 
