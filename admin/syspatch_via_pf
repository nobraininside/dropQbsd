#!/bin/ksh
# ==========================================================
#  dropQbsd -- syspatch_via_pf
#
#  Applies OpenBSD security patches through the restrictive
#  PF ruleset. Populates the <updates> table, runs syspatch,
#  flushes the table on exit to restore default-deny for root.
#
#  Path: /opt/dropQbsd/admin/syspatch_via_pf
#  Permissions: chmod 700, root:wheel
#
#  Usage: syspatch_via_pf
# ==========================================================

ENSURE_SCRIPT="/opt/dropQbsd/libexec/ensure_updates_table"
LOGFILE="/var/log/syspatch_pf.log"
FLUSH_ON_EXIT=1   # Set to 0 to keep the <updates> table populated after run

#-----------------------------------------------------------------------------
# LOG FUNCTION
#-----------------------------------------------------------------------------
log() {
    msg="$1"
    echo "$msg"
    echo "$(date '+%F %T')  $msg" >> "$LOGFILE"
}

#-----------------------------------------------------------------------------
# PRIVILEGE CHECK
#-----------------------------------------------------------------------------
if [ "$(id -u)" -ne 0 ]; then
    echo "Must run as root." >&2
    exit 2
fi

#-----------------------------------------------------------------------------
# DEPENDENCY CHECK
#-----------------------------------------------------------------------------
if [ ! -x "$ENSURE_SCRIPT" ]; then
    echo "FATAL: $ENSURE_SCRIPT not found or not executable." >&2
    exit 1
fi

#-----------------------------------------------------------------------------
# POPULATE PF TABLE
#-----------------------------------------------------------------------------
log "=== syspatch_via_pf starting ==="
"$ENSURE_SCRIPT" || exit $?

#-----------------------------------------------------------------------------
# TRAP FOR GRACEFUL INTERRUPTION AND CLEANUP
#-----------------------------------------------------------------------------
cleanup() {
    log "Interrupted (signal received)."
    if [ "$FLUSH_ON_EXIT" -eq 1 ]; then
        pfctl -t updates -T flush 2>/dev/null
        log "<updates> table flushed."
    else
        log "<updates> table left populated (FLUSH_ON_EXIT=0)."
        log "To flush manually: pfctl -t updates -T flush"
    fi
}
trap cleanup INT TERM EXIT

#-----------------------------------------------------------------------------
# RUN syspatch
#-----------------------------------------------------------------------------
log "Running: syspatch"
syspatch
RC=$?

if [ $RC -eq 0 ]; then
    log "syspatch completed successfully."
else
    log "syspatch exited with code $RC -- check output above."
fi

log "=== syspatch_via_pf finished ==="
exit $RC

