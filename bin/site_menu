#!/bin/ksh
# ==========================================================
#  dropQbsd — site_menu
#
#  Reads ~/dropQbsd/sites.conf and presents a dropdown menu
#  of sites. Selecting a site:
#    - Copies the password to clipboard (via pass) if a
#      pass entry is configured.
#    - Opens the site in a disposable browser (tmpfs-backed,
#      nothing survives exit).
#
#  Path: /opt/dropQbsd/bin/site_menu
#  Permissions: chmod 755, root:wheel
#
#  Requires: zenity, pass, xclip, and a browser
#    (ungoogled-chromium, qutebrowser, or firefox)
#
#  sites.conf format:
#    # Label (ID)|URL|pass_entry (optional)
#    Bank (my_user_id)|https://bank.example.com|finance/bank
#    ERP (my_user_id)|https://enterprise_resource.com|work/erp
#    Linkedin (my_user_id)|https://linkedin.com|social/linkedin
#
#  Lines starting with # are comments.
#  The pass entry is optional — leave empty for sites
#  that don't need authentication.
#
#  Configuration:
#    BROWSER and BROWSER_FLAGS can be set in the environment
#    or at the top of this script. Defaults to ungoogled-chromium
#    with --temp-profile for disposable sessions.
# ==========================================================

CONF="$HOME/dropQbsd/sites.conf"

#-----------------------------------------------------------------------------
# CONFIGURATION
#-----------------------------------------------------------------------------
# Override these via environment or edit directly.
# BROWSER: path to the browser binary.
# BROWSER_FLAGS: flags for disposable/private mode.
BROWSER="${BROWSER:-/usr/local/bin/ungoogled-chromium}"
BROWSER_FLAGS="${BROWSER_FLAGS:---temp-profile}"

# Path to the run_app blind gate (setuid, no doas needed)
RUN_APP="${RUN_APP:-/opt/dropQbsd/bin/run_app}"

# Clipboard clear PID tracker — prevents stale background processes
CLIPBOARD_PID_FILE="/tmp/dropQbsd_clipboard_clear.pid"

#-----------------------------------------------------------------------------
# CHECK DEPENDENCIES
#-----------------------------------------------------------------------------
if ! command -v zenity >/dev/null 2>&1; then
    echo "Error: zenity is required. Install with: pkg_add zenity" >&2
    exit 1
fi

if ! command -v pass >/dev/null 2>&1; then
    echo "Warning: pass not installed. Password integration disabled." >&2
fi

if ! command -v xclip >/dev/null 2>&1; then
    echo "Warning: xclip not installed. Clipboard integration disabled." >&2
fi

if [[ ! -f "$CONF" ]]; then
    echo "Error: $CONF not found." >&2
    exit 1
fi

#-----------------------------------------------------------------------------
# BUILD MENU LIST FOR ZENITY
#-----------------------------------------------------------------------------
# Use printf instead of echo — OpenBSD ksh echo does not interpret \n.
MENU=""
while IFS='|' read -r label url pass_entry; do
    # Skip comments and empty lines
    [[ "$label" == \#* ]] && continue
    [[ -z "$label" ]] && continue

    # Trim whitespace
    label=$(echo "$label" | sed 's/^ *//;s/ *$//')

    MENU="${MENU}${label}\n"
done < "$CONF"

#-----------------------------------------------------------------------------
# SHOW DROPDOWN
#-----------------------------------------------------------------------------
CHOSEN=$(printf "$MENU" | zenity --list \
    --title="dropQbsd Sites" \
    --text="Select a site:" \
    --column="Site" \
    --width=300 --height=400 2>/dev/null)

if [[ -z "$CHOSEN" ]]; then
    exit 0  # User cancelled
fi

#-----------------------------------------------------------------------------
# FIND MATCHING ENTRY AND LAUNCH
#-----------------------------------------------------------------------------
MATCHED=0
while IFS='|' read -r label url pass_entry; do
    [[ "$label" == \#* ]] && continue
    [[ -z "$label" ]] && continue

    label=$(echo "$label" | sed 's/^ *//;s/ *$//')
    url=$(echo "$url" | sed 's/^ *//;s/ *$//')
    pass_entry=$(echo "$pass_entry" | sed 's/^ *//;s/ *$//')

    if [[ "$label" == "$CHOSEN" ]]; then
        MATCHED=1

        # Copy password to clipboard if configured
        if [[ -n "$pass_entry" ]]; then
            if pass show -c "$pass_entry" 2>/dev/null; then
                # Kill any previous clipboard-clearing process
                if [[ -f "$CLIPBOARD_PID_FILE" ]]; then
                    kill "$(cat "$CLIPBOARD_PID_FILE")" 2>/dev/null || true
                fi

                # Clear clipboard after 30 seconds
                (
                    sleep 30
                    printf '' | xclip -selection clipboard 2>/dev/null
                    rm -f "$CLIPBOARD_PID_FILE"
                ) &
                echo $! > "$CLIPBOARD_PID_FILE"
            else
                zenity --warning \
                    --title="dropQbsd" \
                    --text="GPG passphrase expired or password not found.\nRun: pass $pass_entry\nin a terminal to re-enter your GPG passphrase." \
                    --width=400 2>/dev/null
            fi
        fi

        # Launch the disposable browser via the setuid blind gate.
        # No doas needed — run_app escalates to root internally.
        exec "$RUN_APP" --disposable userweb "$BROWSER" $BROWSER_FLAGS "$url"
    fi
done < "$CONF"

#-----------------------------------------------------------------------------
# FALLBACK: label not matched
#-----------------------------------------------------------------------------
if [[ "$MATCHED" -eq 0 ]]; then
    zenity --error \
        --title="dropQbsd" \
        --text="No matching entry found for:\n$CHOSEN" \
        --width=300 2>/dev/null
    exit 1
fi
