#!/bin/ksh
# ==========================================================
#  dropQbsd — qimport
#
#  Imports a file or directory from the /home/drop exchange
#  zone into the conductor's local storage (default:
#  ~/Downloads).
#
#  Cleanup is handled by enforce_drop on its regular cycle.
#  No sentinel is created — the conductor does not write
#  to the drop zone. Files are removed after the abandonment
#  timeout (default: 30 minutes).
#
#  Path: /opt/dropQbsd/bin/qimport
#  Permissions: chmod 755, root:wheel
#
#  Usage: qimport <file_or_directory_in_drop> [destination]
# ==========================================================

set -eu

FILE_INPUT=$1
DEST=${2:-"$HOME/Downloads"}

#-----------------------------------------------------------------------------
# RESOLVE SOURCE PATH
#-----------------------------------------------------------------------------
FILE_DROP=$(realpath "$FILE_INPUT" 2>/dev/null) || true

if [[ -z "$FILE_DROP" ]]; then
    if [[ "$FILE_INPUT" = /* ]]; then
        FILE_DROP="$FILE_INPUT"
    else
        FILE_DROP="$PWD/$FILE_INPUT"
    fi
fi

#-----------------------------------------------------------------------------
# VALIDATE SOURCE IS INSIDE /home/drop
#-----------------------------------------------------------------------------
case "$FILE_DROP" in
    /home/drop/*) ;;
    *)
        echo "Error: can only import files from the drop zone." >&2
        echo "  Path given: $FILE_DROP" >&2
        exit 1
        ;;
esac

#-----------------------------------------------------------------------------
# VERIFY SOURCE EXISTS
#-----------------------------------------------------------------------------
if [[ ! -e "$FILE_DROP" ]]; then
    echo "Error: '$FILE_DROP' not found in the drop zone." >&2
    exit 1
fi

#-----------------------------------------------------------------------------
# VERIFY DESTINATION
#-----------------------------------------------------------------------------
if [[ ! -d "$DEST" ]]; then
    echo "Error: destination '$DEST' does not exist." >&2
    exit 1
fi

if [[ ! -w "$DEST" ]]; then
    echo "Error: destination '$DEST' is not writable." >&2
    exit 1
fi

#-----------------------------------------------------------------------------
# COPY FROM DROP ZONE TO DESTINATION
#-----------------------------------------------------------------------------
FILENAME=$(basename "$FILE_DROP")
TARGET="$DEST/$FILENAME"

if ! cp -pR "$FILE_DROP" "$DEST/"; then
    echo "Error: copy failed." >&2
    exit 1
fi

#-----------------------------------------------------------------------------
# SET LOCAL PERMISSIONS
#-----------------------------------------------------------------------------
chown -R "$USER:$USER" "$TARGET"
find "$TARGET" -type d -exec chmod 700 {} +
find "$TARGET" -type f -exec chmod 600 {} +

echo "Imported: $TARGET"

