# ==========================================================
# dropQbsd -- profile
#
# System-wide shell configuration
# Applied at login for all users.
# Copy to: /etc/profile
#
# Locale notes:
#   LANG, LC_CTYPE, and LC_COLLATE are set to en_US.UTF-8 for consistent
#   system messages, character encoding, and sorting. LC_TIME, LC_MONETARY,
#   and LC_NUMERIC are set to it_IT.UTF-8 in this example -- adjust to your
#   region (e.g. de_DE.UTF-8, fr_FR.UTF-8, es_ES.UTF-8) or set all to
#   en_US.UTF-8 for full English. LC_ALL is intentionally unset to allow
#   the per-category overrides to work.
#
# Before enabling, back up any local overrides:
#
#   mv ~/.profile   ~/.profile.bak
#   mv ~/.kshrc     ~/.kshrc.bak
#   mv ~/.shrc      ~/.shrc.bak
#
# dropQbsd relies on a single, coherent environment across
# all users -- local dotfiles will break domain isolation.
# ==========================================================

# --- Locale: system in English, time/money/numbers in Italian ---
export LANG=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export LC_COLLATE=en_US.UTF-8
export LC_TIME=it_IT.UTF-8
export LC_MONETARY=it_IT.UTF-8
export LC_NUMERIC=it_IT.UTF-8
export LESSCHARSET=utf-8
unset LC_ALL

# --- PATH ---
PATH="/opt/dropQbsd/bin:$PATH"
export PATH

# --- ENV chain: point ksh to the global kshrc ---
export ENV=/etc/kshrc

# --- Conductor reminder (login only, user only) ---
if [ "$(id -un)" = "user" ]; then
    echo "=== dropQbsd conductor ==="
    echo "Domains: userweb (browser) | usermail (email) | userdoc (files)"
    echo "Use qmv/qcp/qimport to move files between domains."
    echo "Keep this account clean -- do your work inside a domain."
fi
