# dropQbsd — example /etc/profile additions
#
# Locale settings — adjust to your region.
export LC_ALL=it_IT.UTF-8
export LANG=it_IT.UTF-8

# Add dropQbsd commands to PATH for all users
PATH="/opt/dropQbsd/bin:$PATH"
export PATH

# Aliases (available to all users)
alias run='/opt/dropQbsd/bin/run_app'
alias runweb='/opt/dropQbsd/bin/run_app --disposable userweb /usr/local/bin/qutebrowser --temp-basedir'
alias runmail='/opt/dropQbsd/bin/run_app usermail /usr/local/bin/claws-mail'
alias rundoc='/opt/dropQbsd/bin/run_app userdoc /usr/local/bin/thunar /home/userdoc'

# Conductor reminder (only shown for user)
if [ "$(id -un)" = "user" ]; then
    echo "=== dropQbsd conductor ==="
    echo "Domains: userweb (browser) | usermail (email) | userdoc (files)"
    echo "Use qmv/qcp/qimport to move files between domains."
    echo "Keep this account clean — do your work inside a domain."
fi
