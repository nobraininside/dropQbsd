# ==========================================================
# dropQbsd -- .xsession
#
# X session startup. Sourced by xenodm at login.
# Copy to: ~/.xsession
#
# Loads the system-wide environment, then launches the
# desktop. Window manager is selected per-user for visual
# domain identification.
# ==========================================================

[ -f /etc/profile ] && . /etc/profile
xrandr --dpi 96

case "$USER" in
    user)
        exec /usr/local/bin/xfce4-session
        ;;
    userweb)
        exec /usr/X11R6/bin/cwm
        ;;
    usermail)
        exec /usr/X11R6/bin/cwm
        ;;
    userdoc)
        exec /usr/local/bin/xfce4-session
        ;;
    root)
        exec /usr/X11R6/bin/cwm
        ;;
    *)
        exec /usr/X11R6/bin/cwm
        ;;
esac
