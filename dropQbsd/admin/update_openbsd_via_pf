#!/bin/ksh
# ==========================================================
#   update_openbsd_via_pf
#
#  Full OpenBSD system update through restrictive PF:
#    1. System patches (syspatch)
#    2. Firmware updates (fw_update)
#    3. Package updates (pkg_add -u)
#    4. Orphan cleanup (pkg_delete -a)
#
#  Path: /usr/local/bin/dropQbsd/admin/update_openbsd_via_pf
#  Permissions: chmod 700, root:wheel
#
#  Usage: update_openbsd_via_pf
#
#  Note: This does NOT perform sysupgrade (major version bump).
#        For release upgrades, run ensure_updates_table first,
#        then sysupgrade manually.
# ==========================================================

ENSURE_SCRIPT="/usr/local/bin/dropQbsd/admin/ensure_updates_table"
PKGADD_SCRIPT="/usr/local/bin/dropQbsd/admin/pkg_add_via_pf"
LOGFILE="/var/log/system_update_pf.log"

#-----------------------------------------------------------------------------
# LOG FUNCTION
#-----------------------------------------------------------------------------
log() {
	msg="$1"
	echo "$msg"
	echo "$(date '+%F %T')  $msg" >> "$LOGFILE"
}

#-----------------------------------------------------------------------------
# PRIVILEGE CHECK
#-----------------------------------------------------------------------------
if [ "$(id -u)" -ne 0 ]; then
	echo "Must run as root." >&2
	exit 2
fi

#-----------------------------------------------------------------------------
# DEPENDENCY CHECKS
#-----------------------------------------------------------------------------
if [ ! -x "$ENSURE_SCRIPT" ]; then
	echo "FATAL: $ENSURE_SCRIPT not found or not executable." >&2
	exit 1
fi
if [ ! -x "$PKGADD_SCRIPT" ]; then
	echo "FATAL: $PKGADD_SCRIPT not found or not executable." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# HEADER
#-----------------------------------------------------------------------------
log "=============================================="
log "== dropQbsd SYSTEM UPDATE ===================="
log "=============================================="

#-----------------------------------------------------------------------------
# TRAP
#-----------------------------------------------------------------------------
cleanup() {
	log ""
	log "Update interrupted (signal received)."
	log "Partial updates may have been applied."
	log "Re-run this script to complete."
}
trap cleanup INT TERM

#-----------------------------------------------------------------------------
# 1. POPULATE PF TABLE (once for all steps)
#-----------------------------------------------------------------------------
log "Step 1/4: Preparing PF table for updates..."
"$ENSURE_SCRIPT" || exit $?

#-----------------------------------------------------------------------------
# 2. SYSTEM PATCHES
#-----------------------------------------------------------------------------
log "Step 2/4: Applying system patches (syspatch)..."
syspatch >> "$LOGFILE" 2>&1
RC_SP=$?
if [ $RC_SP -eq 0 ]; then
	log "  syspatch: OK"
elif [ $RC_SP -eq 2 ]; then
	log "  syspatch: no patches available (code  normal)"
else
	log "  syspatch: exited with code $RC_ check log"
fi

#-----------------------------------------------------------------------------
# 3. FIRMWARE UPDATES
#-----------------------------------------------------------------------------
log "Step 3/4: Updating firmware (fw_update)..."
fw_update >> "$LOGFILE" 2>&1
RC_FW=$?
if [ $RC_FW -eq 0 ]; then
	log "  fw_update: OK"
else
	log "  fw_update: exited with code $RC_ check log"
fi

#-----------------------------------------------------------------------------
# 4. PACKAGE UPDATES + ORPHAN CLEANUP
#-----------------------------------------------------------------------------
log "Step 4/4: Updating packages (pkg_add -u)..."
"$PKGADD_SCRIPT" -u
RC_PKG=$?

if [ $RC_PKG -eq 0 ]; then
	log "  Package update: OK"

	log "  Cleaning orphaned packages (pkg_delete -aI)..."
	pkg_delete -aI >> "$LOGFILE" 2>&1
	log "  Orphan cleanup: done"
else
	log "  Package update: exited with code $RC_ skipping orphan cleanup"
fi

#-----------------------------------------------------------------------------
# SUMMARY
#-----------------------------------------------------------------------------
log "----------------------------------------------"
log "Update complete."
log "  syspatch:    $RC_SP"
log "  fw_update:   $RC_FW"
log "  pkg_add -u:  $RC_PKG"
log "Full log: $LOGFILE"
log "----------------------------------------------"

exit 0
 
