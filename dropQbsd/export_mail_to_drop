#!/bin/ksh
# /usr/local/bin/qubsd/export_mail_to_drop
set -eu
umask 002

SRC="/home/usermail/.mail"
DST="/home/drop/usermail_export"

[ -d "$SRC" ] || { echo "[ERRORE] Directory '$SRC' non trovata." >&2; exit 1; }

TMPDIR=$(mktemp -d /home/usermail/mail_exp.XXXXXX)
trap 'rm -rf "$TMPDIR"' EXIT INT TERM

# 1. Controllo spazio critico
if [ "$(df -P /home | awk 'NR==2 {print $5+0}')" -gt 92 ]; then
    echo "[ERRORE] Utilizzo /home > 92%." >&2
    exit 1
fi

# 2. Preparazione destinazione
mkdir -p "$DST"

# 3. Compressione con priorità ridotta
ARCHIVE="$TMPDIR/mail_$(date +%Y%m%d_%H%M%S).tar.gz"
nice -n 10 tar -czf "$ARCHIVE" -C "$SRC" .

# 4. Verifica archivio prima del trasferimento
if ! tar -tzf "$ARCHIVE" >/dev/null 2>&1; then
    echo "[ERRORE] Archivio corrotto dopo la compressione." >&2
    exit 1
fi

# 5. Trasferimento con permessi espliciti
cp "$ARCHIVE" "$DST/"
chmod 440 "$DST/$(basename "$ARCHIVE")"

# 6. Pulizia archivi più vecchi di 2 ore
find "$DST" -type f -name 'mail_*.tar.gz' -mmin +120 -delete

