#!/bin/ksh
# /usr/local/bin/qubsd/qimport <file_o_cartella_in_drop> [destinazione]

FILE_INPUT=$1
FILE_DROP=$(realpath "$FILE_INPUT" 2>/dev/null)

if [[ -z "$FILE_DROP" ]]; then
    [[ "$FILE_INPUT" = /* ]] && FILE_DROP="$FILE_INPUT" || FILE_DROP="$PWD/$FILE_INPUT"
fi

DEST=$2

# Verifica che il file provenga da DROP
case "$FILE_DROP" in
    /home/drop/*) ;;
    *) echo "Errore: puoi importare solo file/cartelle dal Drop. (Path rilevato: $FILE_DROP)"; exit 1 ;;
esac

# Imposta destinazione di default
if [[ -z "$DEST" ]]; then
    DEST="$HOME/Downloads"
fi

# Verifica esistenza destinazione
if [[ ! -d "$DEST" ]]; then
    echo "Errore: destinazione '$DEST' non trovata."
    exit 1
fi

# Copia ricorsiva
if ! cp -pR "$FILE_DROP" "$DEST/"; then
    echo "Errore: Copia fallita."
    exit 1
fi

# Gestione permessi e proprietà in destinazione
FILENAME=$(basename "$FILE_DROP")
TARGET="$DEST/$FILENAME"

chown -R "$USER":"$USER" "$TARGET"
find "$TARGET" -type d -exec chmod 700 {} +
find "$TARGET" -type f -exec chmod 600 {} +

# Creazione sentinella nella dogana
SENTINEL="${FILE_DROP}.imported"
touch "$SENTINEL" 2>/dev/null || true

# Se touch fallisce (directory senza permesso w), non è critico:
# enforce_drop pulirà comunque i file vecchi

echo "Importato in $TARGET con successo."
