#!/bin/sh
# ==========================================================
#  QuBSD – Metodo di compartimentalizzazione multi‑utente per OpenBSD
#  ----------------------------------------------------------
#  Un metasistema leggero e trasparente per l’uso quotidiano:
#    • sicurezza nativa, senza hypervisor
#    • isolamenti orizzontali per dominio (web, mail, LAN, user)
#    • flussi file controllati e unidirezionali (Drop • Sync)
#    • configurazioni testuali, ricostruibili in mezz’ora
#  "OpenBSD orchestrato – Compartimentalizzazione human friendly"
# ==========================================================

# ============================================
# Script /home/userweb/bin/export_sites_to_drop
# per backup dei siti Flat File CMS verso Drop (fase 1)
# Script abbinato a /home/userlan/bin/pull_sites_from_drop
# ============================================

#!/bin/sh
set -eu
umask 002

SRC="/home/userweb/Documents/sites"
DST="/home/drop/userweb_export"

[ -d "$SRC" ] || { echo "[ERRORE] Directory '$SRC' non trovata." >&2; exit 1; }

TMPDIR=$(mktemp -d /home/userweb/tmp_export.XXXXXX)
trap 'rm -rf "$TMPDIR"' EXIT INT TERM

VERBOSE=0
[ "${1:-}" = "-v" ] && VERBOSE=1
msg() { [ "$VERBOSE" -eq 1 ] && echo "[INFO] $*"; }

# 1. Controllo spazio libero
if [ "$(df -P /home | awk 'NR==2 {print $5+0}')" -gt 90 ]; then
    echo "[ERRORE] Utilizzo /home > 90%." >&2
    exit 1
fi

# 2. Preparazione destinazione
mkdir -p "$DST"

# 3. Compressione
ARCHIVE="$TMPDIR/sites_$(date +%Y%m%d_%H%M%S).tar.gz"
msg "Compressione in corso: $ARCHIVE"
tar -czf "$ARCHIVE" -C "$SRC" .

# 4. Verifica archivio prima del trasferimento
if ! tar -tzf "$ARCHIVE" >/dev/null 2>&1; then
    echo "[ERRORE] Archivio corrotto dopo la compressione." >&2
    exit 1
fi

# 5. Trasferimento con permessi espliciti
cp "$ARCHIVE" "$DST/"
chmod 440 "$DST/$(basename "$ARCHIVE")"

# 6. Pulizia archivi più vecchi di 24 ore
find "$DST" -type f -name 'sites_*.tar.gz' -mtime +0 -delete

msg "Operazione completata con successo."

