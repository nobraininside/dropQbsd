#!/bin/ksh
# ==========================================================
#  dropQbsd — sysupgrade_via_pf
#
#  Upgrades OpenBSD to the next release through restrictive
#  PF. Populates the <updates> table, runs sysupgrade.
#  If sysupgrade fails and returns (no reboot), the table
#  is flushed to restore default-deny for root.
#
#  Run update_openbsd_via_pf first to ensure all patches
#  and packages are current.
#
#  Path: /usr/local/bin/dropQbsd/admin/sysupgrade_via_pf
#  Permissions: chmod 700, root:wheel
#
#  Usage: sysupgrade_via_pf
#
#  WARNING: sysupgrade downloads the new base system and
#  reboots automatically on success.
# ==========================================================

ENSURE_SCRIPT="/usr/local/bin/dropQbsd/admin/ensure_updates_table"
LOGFILE="/var/log/sysupgrade_pf.log"
FLUSH_ON_EXIT=1

log() {
    msg="$1"
    echo "$msg"
    echo "$(date '+%F %T')  $msg" >> "$LOGFILE"
}

if [ "$(id -u)" -ne 0 ]; then
    echo "Must run as root." >&2
    exit 2
fi

if [ ! -x "$ENSURE_SCRIPT" ]; then
    echo "FATAL: $ENSURE_SCRIPT not found or not executable." >&2
    exit 1
fi

log "=== sysupgrade_via_pf starting ==="
"$ENSURE_SCRIPT" || exit $?

cleanup() {
    log "Interrupted or sysupgrade returned without rebooting."
    if [ "$FLUSH_ON_EXIT" -eq 1 ]; then
        pfctl -t updates -T flush 2>/dev/null
        log "<updates> table flushed."
    else
        log "<updates> table left populated (FLUSH_ON_EXIT=0)."
        log "To flush manually: pfctl -t updates -T flush"
    fi
}
trap cleanup INT TERM EXIT

log "Running: sysupgrade"
sysupgrade
RC=$?

# sysupgrade normally reboots before reaching this point.
log "sysupgrade exited with code $RC — no reboot occurred."
log "=== sysupgrade_via_pf finished ==="
exit $RC
