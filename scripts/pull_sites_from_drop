#!/bin/ksh
# ==========================================================
#  dropQbsd — pull_sites_from_drop
#
#  Pulls the latest sites archive from the drop zone into
#  userdoc's Sync directory. Verifies integrity, creates
#  a sentinel for enforce_drop cleanup, and keeps the
#  3 most recent archives locally.
#
#  Path: /usr/local/bin/dropQbsd/pull_sites_from_drop
#  Permissions: chmod 755, root:wheel
#
#  Usage: pull_sites_from_drop (run as userdoc)
# ==========================================================

set -eu

SRC="/home/drop/userweb_export"
DST="/home/userdoc/Sync/Archivio/Archivio_siti"

#-----------------------------------------------------------------------------
# PRE-FLIGHT CHECKS
#-----------------------------------------------------------------------------
if [ ! -d "$SRC" ]; then
	echo "Error: $SRC not accessible." >&2
	exit 1
fi

mkdir -p "$DST"

#-----------------------------------------------------------------------------
# 1. FIND THE LATEST ARCHIVE
#-----------------------------------------------------------------------------
LATEST=$(ls -1t "$SRC"/sites_*.tar.gz 2>/dev/null | head -1)

if [ -z "$LATEST" ]; then
	echo "No archive found in $SRC."
	exit 0
fi

FILENAME=$(basename "$LATEST")

#-----------------------------------------------------------------------------
# 2. SKIP IF ALREADY PRESENT
#-----------------------------------------------------------------------------
if [ -f "$DST/$FILENAME" ]; then
	echo "File $FILENAME already present in destination. Skipped."
	exit 0
fi

#-----------------------------------------------------------------------------
# 3. COPY AND SET PERMISSIONS
#-----------------------------------------------------------------------------
cp "$LATEST" "$DST/"
chmod 600 "$DST/$FILENAME"

#-----------------------------------------------------------------------------
# 4. VERIFY INTEGRITY
#-----------------------------------------------------------------------------
if tar -tzf "$DST/$FILENAME" >/dev/null 2>&1; then
	echo "Archive $FILENAME imported and verified successfully."
else
	echo "ERROR: Archive $FILENAME is corrupt!"
	rm "$DST/$FILENAME"
	exit 1
fi

#-----------------------------------------------------------------------------
# 5. CREATE SENTINEL FOR enforce_drop
#-----------------------------------------------------------------------------
SENTINEL="${LATEST}.imported"
touch "$SENTINEL" 2>/dev/null || true

#-----------------------------------------------------------------------------
# 6. KEEP ONLY THE 3 MOST RECENT ARCHIVES LOCALLY
#-----------------------------------------------------------------------------
cd "$DST" || exit 1
ls -1t sites_*.tar.gz 2>/dev/null | tail -n +4 | xargs rm 2>/dev/null

echo ">>> Sites sync completed."
