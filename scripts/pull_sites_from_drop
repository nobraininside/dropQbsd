#!/bin/ksh
# /home/userlan/bin/pull_sites_from_drop
set -eu

SRC="/home/drop/userweb_export"
DST="/home/userdoc/Sync/Archivio/Archivio_siti"

[ -d "$SRC" ] || { echo "Errore: $SRC non accessibile"; exit 1; }
mkdir -p "$DST"

# 1. Trova il file più recente nella sorgente
LATEST=$(ls -1t "$SRC"/sites_*.tar.gz 2>/dev/null | head -1)

if [ -z "$LATEST" ]; then
    echo "Nessun archivio trovato in $SRC"
    exit 0
fi

FILENAME=$(basename "$LATEST")

# 2. Copia solo se non esiste già in destinazione
if [ -f "$DST/$FILENAME" ]; then
    echo "Il file $FILENAME è già presente in destinazione. Saltato."
    exit 0
fi

# 3. Copia con permessi utente (600 per file)
cp "$LATEST" "$DST/"
chmod 600 "$DST/$FILENAME"

# 4. Verifica integrità (tar -t controlla l'archivio senza estrarre)
if tar -tzf "$DST/$FILENAME" >/dev/null 2>&1; then
    echo "Archivio $FILENAME importato e verificato con successo."
else
    echo "ERRORE: Archivio $FILENAME corrotto!"
    rm "$DST/$FILENAME"
    exit 1
fi

# 5. Creazione sentinella nella dogana
SENTINEL="${LATEST}.imported"
touch "$SENTINEL" 2>/dev/null || true

# 6. Pulizia locale: tieni solo gli ultimi 3 archivi
cd "$DST" || exit 1
ls -1t sites_*.tar.gz 2>/dev/null | tail -n +4 | xargs -r rm


