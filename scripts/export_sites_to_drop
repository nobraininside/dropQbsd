#!/bin/ksh
# ==========================================================
#  dropQbsd — export_sites_to_Drop
#
#  Compresses the userweb sites directory and places the
#  archive in /home/drop/userweb_export for archival by
#  userdoc.
#
#  Permissions on the exported archive are enforced by
#  enforce_drop (cron), not by this script — the export
#  directory is owned by root:drop, so userweb cannot
#  chmod files there.
#
#  Path: /usr/local/bin/dropQbsd/export_sites_to_Drop.sh
#  Permissions: chmod 755, root:wheel
#
#  Usage: export_sites_to_Drop.sh [-v]   (run as userweb)
#    -v   Verbose output
# ==========================================================

set -eu
umask 002

SRC="/home/userweb/Documents/sites"
DST="/home/drop/userweb_export"

#-----------------------------------------------------------------------------
# VERBOSE FLAG
#-----------------------------------------------------------------------------
VERBOSE=0
[ "${1:-}" = "-v" ] && VERBOSE=1
msg() { [ "$VERBOSE" -eq 1 ] && echo "[INFO] $*"; }

#-----------------------------------------------------------------------------
# PRE-FLIGHT CHECKS
#-----------------------------------------------------------------------------
if [ ! -d "$SRC" ]; then
	echo "[ERROR] Source directory '$SRC' not found." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# DISK SPACE CHECK
#-----------------------------------------------------------------------------
if [ "$(df -P /home | awk 'NR==2 {print $5+0}')" -gt 90 ]; then
	echo "[ERROR] /home usage > 90%. Aborting." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# PREPARE DESTINATION
#-----------------------------------------------------------------------------
mkdir -p "$DST"

#-----------------------------------------------------------------------------
# COMPRESS
#-----------------------------------------------------------------------------
TMPDIR=$(mktemp -d /home/userweb/tmp_export.XXXXXX)
trap 'rm -rf "$TMPDIR"' EXIT INT TERM

ARCHIVE="$TMPDIR/sites_$(date +%Y%m%d_%H%M%S).tar.gz"
msg "Compressing: $ARCHIVE"
tar -czf "$ARCHIVE" -C "$SRC" .

#-----------------------------------------------------------------------------
# VERIFY ARCHIVE INTEGRITY
#-----------------------------------------------------------------------------
if ! tar -tzf "$ARCHIVE" >/dev/null 2>&1; then
	echo "[ERROR] Archive corrupt after compression." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# TRANSFER TO DROP ZONE
#-----------------------------------------------------------------------------
# enforce_drop (cron, every 60s) will set the correct 440 permissions.
# userweb cannot chmod here — the export directory is root:drop.
cp "$ARCHIVE" "$DST/"

#-----------------------------------------------------------------------------
# ROTATE OLD ARCHIVES (> 24 hours)
#-----------------------------------------------------------------------------
find "$DST" -type f -name 'sites_*.tar.gz' -mtime +0 -delete 2>/dev/null

msg "Export completed successfully."
