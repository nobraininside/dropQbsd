#!/bin/ksh
# ==========================================================
#  dropQbsd — export_mail_to_drop
#
#  Compresses the usermail directory and places the archive
#  in /home/drop/usermail_export for archival by userdoc.
#
#  Permissions on the exported archive are enforced by
#  enforce_drop (cron), not by this script — the export
#  directory is owned by root:drop, so usermail cannot
#  chmod files there.
#
#  Path: /usr/local/bin/dropQbsd/export_mail_to_drop
#  Permissions: chmod 755, root:wheel
#
#  Usage: export_mail_to_drop (run as usermail)
# ==========================================================

set -eu
umask 002

SRC="/home/usermail/.mail"
DST="/home/drop/usermail_export"

#-----------------------------------------------------------------------------
# PRE-FLIGHT CHECKS
#-----------------------------------------------------------------------------
if [ ! -d "$SRC" ]; then
	echo "[ERROR] Source directory '$SRC' not found." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# DISK SPACE CHECK
#-----------------------------------------------------------------------------
if [ "$(df -P /home | awk 'NR==2 {print $5+0}')" -gt 92 ]; then
	echo "[ERROR] /home usage > 92%. Aborting." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# PREPARE DESTINATION
#-----------------------------------------------------------------------------
mkdir -p "$DST"

#-----------------------------------------------------------------------------
# COMPRESS (low priority)
#-----------------------------------------------------------------------------
TMPDIR=$(mktemp -d /home/usermail/mail_exp.XXXXXX)
trap 'rm -rf "$TMPDIR"' EXIT INT TERM

ARCHIVE="$TMPDIR/mail_$(date +%Y%m%d_%H%M%S).tar.gz"
nice -n 10 tar -czf "$ARCHIVE" -C "$SRC" .

#-----------------------------------------------------------------------------
# VERIFY ARCHIVE INTEGRITY
#-----------------------------------------------------------------------------
if ! tar -tzf "$ARCHIVE" >/dev/null 2>&1; then
	echo "[ERROR] Archive corrupt after compression." >&2
	exit 1
fi

#-----------------------------------------------------------------------------
# TRANSFER TO DROP ZONE
#-----------------------------------------------------------------------------
# enforce_drop (cron, every 60s) will set the correct 440 permissions.
# usermail cannot chmod here — the export directory is root:drop.
cp "$ARCHIVE" "$DST/"

#-----------------------------------------------------------------------------
# ROTATE OLD ARCHIVES (> 2 hours)
#-----------------------------------------------------------------------------
find "$DST" -type f -name 'mail_*.tar.gz' -mmin +120 -delete 2>/dev/null
