#!/bin/ksh
# ==========================================================
#  dropQbsd — qmv
#
#  Moves a file or directory into the /home/drop exchange
#  zone and sets correct permissions atomically.
#
#  The original is deleted ONLY after the copy is verified
#  and permissions are locked down. This prevents data loss
#  and closes the TOCTOU window where files sit in the drop
#  zone with their original (potentially too open) permissions.
#
#  Workflow:
#    1. Copy to a staging location inside /home/drop with
#       restricted permissions from the start.
#    2. Set group and final permissions.
#    3. Verify the copy succeeded.
#    4. Only then delete the original.
#
#  Path: /usr/local/bin/dropQbsd/qmv
#  Permissions: chmod 755, root:wheel
#
#  Usage: qmv <file_or_directory>
# ==========================================================

set -eu

TARGET=$1
DST="/home/drop"

#-----------------------------------------------------------------------------
# ARGUMENT VALIDATION
#-----------------------------------------------------------------------------
if [ -z "$TARGET" ]; then
    echo "Usage: qmv <file_or_directory>" >&2
    exit 1
fi

if [ ! -e "$TARGET" ]; then
    echo "Error: '$TARGET' not found." >&2
    exit 1
fi

# Refuse to operate on anything already inside /home/drop.
# This prevents accidental deletion of files in the exchange zone
# and blocks a confused-deputy attack where a compromised domain
# tries to qmv files it shouldn't touch.
case "$(realpath "$TARGET")" in
    /home/drop|/home/drop/*)
        echo "Error: '$TARGET' is already inside the drop zone." >&2
        exit 1
        ;;
esac

# Refuse to operate on system-critical paths.
# This is a safety net — it should never trigger under normal use,
# but prevents catastrophic damage from bugs or malicious input.
case "$(realpath "$TARGET")" in
    /|/bin|/sbin|/usr|/etc|/var|/home|/root|/tmp)
        echo "Error: refusing to move system path '$TARGET'." >&2
        exit 1
        ;;
esac

#-----------------------------------------------------------------------------
# PREPARE STAGING NAME
#-----------------------------------------------------------------------------
NAME=$(basename "$TARGET")
DEST_PATH="$DST/$NAME"

#-----------------------------------------------------------------------------
# COPY TO STAGING WITH RESTRICTED PERMISSIONS FROM THE START
#-----------------------------------------------------------------------------
# Strategy: copy into a staging location, lock permissions immediately,
# then atomically rename into place. This eliminates the TOCTOU window
# where files sit in /home/drop with original (potentially open) permissions
# before enforce_drop's next cycle.

STAGING="$DST/.staging.$$.$(date +%s)"
mkdir "$STAGING"
chmod 700 "$STAGING"          # nobody else can enter during setup

# Copy into staging
cp -pR "$TARGET" "$STAGING/$NAME"

# cp -pR preserved the source permissions. Re-apply write permission
# on the staging directory so mv can remove files from it.
chmod 700 "$STAGING"

# Lock permissions inside staging immediately — before anyone can see them
chgrp -R drop "$STAGING/$NAME"
find "$STAGING/$NAME" -type d -exec chmod 700 {} +
find "$STAGING/$NAME" -type f -exec chmod 440 {} +

#-----------------------------------------------------------------------------
# VERIFY THE COPY SUCCEEDED BEFORE DELETING THE ORIGINAL
#-----------------------------------------------------------------------------
# Compare file count and total size between source and staging copy.
# This catches partial copies from disk-full or I/O errors.
SRC_COUNT=$(find "$TARGET" -type f 2>/dev/null | wc -l | tr -d ' ')
DST_COUNT=$(find "$STAGING/$NAME" -type f 2>/dev/null | wc -l | tr -d ' ')

if [ "$SRC_COUNT" -ne "$DST_COUNT" ]; then
    echo "Error: copy verification failed (source: $SRC_COUNT files, dest: $DST_COUNT files)." >&2
    echo "Original '$TARGET' has NOT been deleted." >&2
    rm -rf "$STAGING"
    exit 1
fi

#-----------------------------------------------------------------------------
# MOVE STAGING INTO PLACE (atomic on same filesystem)
#-----------------------------------------------------------------------------
mv "$STAGING/$NAME" "$DEST_PATH"
rmdir "$STAGING" 2>/dev/null || true

# If rmdir failed, the staging directory wasn't empty.
# Log it and clean up forcefully.
if [ -d "$STAGING" ]; then
    echo "Warning: staging directory not empty after  forcing cleanup." >&2
    rm -rf "$STAGING"
fi


#-----------------------------------------------------------------------------
# DELETE THE ORIGINAL — ONLY NOW, AFTER EVERYTHING SUCCEEDED
#-----------------------------------------------------------------------------
rm -rf "$TARGET"

