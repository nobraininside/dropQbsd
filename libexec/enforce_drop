#!/bin/ksh
# ==========================================================
#  dropQbsd -- enforce_drop
#
#  Polices the /home/drop exchange directory.
#  Runs every minute via cron as root.
#
#  Responsibilities:
#    1. Enforce correct permissions (440 files, 570 dirs).
#    2. Quarantine files with wrong GID (not 'drop' group)
#       with an explanation ticket.
#    3. Clean up abandoned files/dirs older than 30 minutes.
#    4. Grace period: skip files younger than 2 minutes to
#       avoid races with qmv still writing.
#    5. Sanitize export directories (userweb_export,
#       usermail_export) with SGID enforcement and old
#       archive rotation.
#
#  No sentinel processing. Files are cleaned up by timeout
#  only -- this keeps the conductor (user) from needing
#  write access to the drop zone.
#
#  Path: /opt/dropQbsd/libexec/enforce_drop
#  Permissions: chmod 700, root:wheel
#
#  Cron: * * * * * /opt/dropQbsd/libexec/enforce_drop
#
#  Note: OpenBSD ksh has no 'dotglob'. We iterate over
#  both '*' and '.*' to catch dotfiles, skipping '.' and
#  '..' explicitly.
# ==========================================================

LOCKDIR="/var/run/enforce_drop.lock"

# Clean up stale lock file from older script versions
if [ -f "$LOCKDIR" ]; then
    rm -f "$LOCKDIR"
fi

# Acquire non-blocking lock using mkdir (atomic on Unix)
if ! mkdir "$LOCKDIR" 2>/dev/null; then
    exit 0
fi
trap 'rmdir "$LOCKDIR"' EXIT

DROP_DIR="/home/drop"
QUARANTINE_DIR="$DROP_DIR/_quarantine"
LOG_FILE="/var/log/dropQbsd_drop.log"

GRACE_MIN=2
ABANDON_MIN=30

#-----------------------------------------------------------------------------
# READ THE GID OF THE 'drop' GROUP FROM /etc/group
#-----------------------------------------------------------------------------
DROP_GID=$(grep ^drop: /etc/group | cut -d: -f3)
if [ -z "$DROP_GID" ]; then
    echo "$(date '+%F %T') FATAL: group 'drop' not found in /etc/group" \
        >> "$LOG_FILE"
    exit 1
fi

#-----------------------------------------------------------------------------
# ENSURE QUARANTINE DIRECTORY EXISTS
#-----------------------------------------------------------------------------
mkdir -p "$QUARANTINE_DIR"
chmod 750 "$QUARANTINE_DIR"

#-----------------------------------------------------------------------------
# CHANGE TO DROP DIRECTORY
#-----------------------------------------------------------------------------
cd "$DROP_DIR" || exit 1

#-----------------------------------------------------------------------------
# LOG FUNCTION
#-----------------------------------------------------------------------------
log() {
    echo "$(date '+%F %T')  $1" >> "$LOG_FILE"
}

#-----------------------------------------------------------------------------
# COUNTERS FOR SUMMARY LOG
#-----------------------------------------------------------------------------
ABANDONED_DELETED=0
QUARANTINED=0
PERMS_FIXED=0
CYCLE_FILES=0

#-----------------------------------------------------------------------------
# 1. MAIN SANITIZATION LOOP
#-----------------------------------------------------------------------------
for item in * .*; do

    [[ "$item" == "." || "$item" == ".." ]] && continue

    # Skip special directories
    [[ "$item" == "_quarantine" ]] && continue
    [[ "$item" == "ISTRUZIONI.txt" ]] && continue
    [[ "$item" == *"_export" ]] && continue

    #---------------------------------------------------------------------
    # 1a. GRACE PERIOD -- skip files younger than GRACE_MIN
    # 1b. ABANDONED FILE CLEANUP -- delete files older than ABANDON_MIN
    #---------------------------------------------------------------------
    # Use a single stat call instead of two find invocations.
    FILE_MTIME=$(stat -f '%m' "$item" 2>/dev/null)
    if [[ -n "$FILE_MTIME" ]]; then
	NOW=$(date +%s)
	AGE=$((NOW - FILE_MTIME))

	if [ "$AGE" -lt $((GRACE_MIN * 60)) ]; then
    	    continue
	fi

	if [ "$AGE" -gt $((ABANDON_MIN * 60)) ]; then
    	    rm -rf "$item"
    	    ABANDONED_DELETED=$((ABANDONED_DELETED + 1))
    	    continue
	fi
    fi

    #---------------------------------------------------------------------
    # 1c. GID VERIFICATION
    #---------------------------------------------------------------------
    FILE_GID=$(stat -f %g "$item" 2>/dev/null)
    FILE_UID=$(stat -f %u "$item" 2>/dev/null)

    if [ "$FILE_GID" -ne "$DROP_GID" ] && [ "$FILE_UID" -ne 0 ]; then
        TS=$(date +%s)
        QUAR_NAME="${item}_${TS}"

        mv "$item" "$QUARANTINE_DIR/$QUAR_NAME"

        cat <<EOF > "$QUARANTINE_DIR/${QUAR_NAME}.txt"
-----------------------------------------------------------
QUARANTINE -- dropQbsd enforce_drop
-----------------------------------------------------------
File:     "$item"
Date:     $(date '+%Y-%m-%d %H:%M:%S')
Reason:   Wrong GID detected.
          Expected GID: $DROP_GID (group 'drop')
          Actual GID:   $FILE_GID
          Actual UID:   $FILE_UID

Action required:
  Investigate why this file has the wrong group ownership.
  If legitimate, move it back with correct permissions:
    mv _quarantine/$QUAR_NAME .
    chgrp drop $item
    chmod 440 $item   # for files
    chmod 570 $item   # for directories

  If malicious or unknown, delete it.
-----------------------------------------------------------
EOF
        QUARANTINED=$((QUARANTINED + 1))
        continue
    fi

    #---------------------------------------------------------------------
    # 1d. PERMISSION CORRECTION
    #---------------------------------------------------------------------
    # Extract octal mode from stat -r output (field 3) and mask to 07777
    CURRENT_MODE=$(stat -r "$item" 2>/dev/null | awk '{print $3}')
    CURRENT_PERM=$(printf '%o' $((CURRENT_MODE & 07777)))

    if [ -d "$item" ]; then
        if [ "$CURRENT_PERM" != "570" ]; then
            chmod 570 "$item"
            PERMS_FIXED=$((PERMS_FIXED + 1))
        fi
    elif [ -f "$item" ]; then
        if [ "$CURRENT_PERM" != "440" ]; then
            chmod 440 "$item"
            PERMS_FIXED=$((PERMS_FIXED + 1))
        fi
    fi

    CYCLE_FILES=$((CYCLE_FILES + 1))
done

#-----------------------------------------------------------------------------
# 2. EXPORT DIRECTORY SANITIZATION
#-----------------------------------------------------------------------------
# Rotation happens FIRST -- before chown/chmod -- so that mtime is not
# reset by permission fixes, which would prevent files from ever aging out.
for exdir in "$DROP_DIR/userweb_export" "$DROP_DIR/usermail_export"; do
    if [[ ! -d "$exdir" ]]; then
        continue
    fi

    # Mail archives: delete after 6 hours (generous margin for large exports)
    find "$exdir" -type f -name 'mail_*.tar.gz' -mmin +360 -delete 2>/dev/null

    # www archives: delete after 4 hours
    find "$exdir" -type f -name 'www_*.tar.gz' -mmin +240 -delete 2>/dev/nulll

    # Fix ownership (only files that need it -- preserves mtime on clean files)
    find "$exdir" \( ! -user root -o ! -group drop \) -exec chown root:drop {} + 2>/dev/null

    # Enforce SGID and permissions on directories (2770)
    find "$exdir" -type d ! -perm 2770 -exec chmod 2770 {} + 2>/dev/null

    # Enforce read-only permissions on files (440)
    find "$exdir" -type f ! -perm 440 -exec chmod 440 {} + 2>/dev/null
done


#-----------------------------------------------------------------------------
# 3. LOG SUMMARY (only if something happened)
#-----------------------------------------------------------------------------
TOTAL_ACTIONS=$((ABANDONED_DELETED + QUARANTINED + PERMS_FIXED))
if [ "$TOTAL_ACTIONS" -gt 0 ]; then
    log "Cycle complete:" \
        "abandoned=$ABANDONED_DELETED" \
        "quarantined=$QUARANTINED" \
        "perms_fixed=$PERMS_FIXED"
fi

if [ "$CYCLE_FILES" -gt 50 ]; then
    log "WARNING: $CYCLE_FILES files in drop zone -- possible abuse or stuck pipeline"
fi

exit 0
