#!/bin/ksh
# ==========================================================
#  dropQbsd — verify_integrity
#
#  Checks the integrity of critical dropQbsd scripts using
#  signify(1). Run periodically via cron to detect tampering.
#
#  Setup (one-time, private key kept offline):
#    signify -G -n -p /etc/tables/dropQbsd.pub -s /root/dropQbsd.sec
#    sha256 /opt/dropQbsd/libexec/run_app_impl \
#           /opt/dropQbsd/bin/qmv \
#           /opt/dropQbsd/bin/qcp \
#           /opt/dropQbsd/bin/qimport \
#           /opt/dropQbsd/libexec/enforce_drop \
#           /opt/dropQbsd/libexec/enforce_sync \
#      | signify -S -s /root/dropQbsd.sec -m - \
#          -x /etc/tables/dropQbsd_scripts.sha256.sig
#    rm /root/dropQbsd.sec
#
#  Path: /opt/dropQbsd/libexec/verify_integrity
#  Permissions: chmod 700, root:wheel
#
#  Cron: */5 * * * * /opt/dropQbsd/libexec/verify_integrity
# ==========================================================

PUBKEY="/opt/dropQbsd/tables/dropQbsd.pub"
CHECKSUM_FILE="/opt/dropQbsd/tables/dropQbsd_scripts.sha256.sig"
SCRIPT_DIR="/opt/dropQbsd"

if [[ ! -f "$PUBKEY" ]] || [[ ! -f "$CHECKSUM_FILE" ]]; then
    exit 0
fi

if ! signify -C -p "$PUBKEY" -x "$CHECKSUM_FILE" \
    "$SCRIPT_DIR/libexec/run_app_impl" \
    "$SCRIPT_DIR/bin/qmv" \
    "$SCRIPT_DIR/bin/qcp" \
    "$SCRIPT_DIR/bin/qimport" \
    "$SCRIPT_DIR/libexec/enforce_drop" \
    "$SCRIPT_DIR/libexec/enforce_sync" \
    >/dev/null 2>&1; then
    logger -t dropQbsd "INTEGRITY VIOLATION: one or more scripts have been modified"
fi
