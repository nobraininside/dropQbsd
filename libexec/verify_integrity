#!/bin/ksh
# ==========================================================
#  dropQbsd -- verify_integrity
#
#  Checks the integrity of critical dropQbsd scripts using
#  signify(1). Run periodically via cron to detect tampering.
#  Logs to /var/log/dropQbsd_integrity.log.
#
#  Setup (one-time, private key kept offline):
#    cd /opt/dropQbsd
#    rm -f keys/dropQbsd.pub keys/dropQbsd_scripts.sha256.sig
#    signify -G -n -p keys/dropQbsd.pub -s /root/dropQbsd.sec
#    sha256 libexec/run_app_impl bin/qmv bin/qcp bin/qimport \
#           libexec/enforce_drop libexec/enforce_sync \
#      | signify -S -s /root/dropQbsd.sec -m - \
#          -x keys/dropQbsd_scripts.sha256.sig
#    rm /root/dropQbsd.sec
#
#  Path: /opt/dropQbsd/libexec/verify_integrity
#  Permissions: chmod 700, root:wheel
#
#  Cron: */5 * * * * /opt/dropQbsd/libexec/verify_integrity
# ==========================================================

PUBKEY="/opt/dropQbsd/keys/dropQbsd.pub" 
CHECKSUM_FILE="/opt/dropQbsd/keys/dropQbsd_scripts.sha256.sig" 
SCRIPT_DIR="/opt/dropQbsd" 
LOG="/var/log/dropQbsd_integrity.log" 
TMP="/tmp/verify_integrity_$$" 

cd "$SCRIPT_DIR" || exit 1 

sha256 libexec/run_app_impl bin/qmv bin/qcp bin/qimport \ 
    libexec/enforce_drop libexec/enforce_sync > "$TMP" 2>&1 

OUTPUT=$(signify -V -p "$PUBKEY" -x "$CHECKSUM_FILE" -m "$TMP" 2>&1) 
RET=$? 
rm -f "$TMP" 

if [ $RET -eq 0 ]; then 
    printf '%s: OK\n' "$(date)" >> "$LOG" 
else 
    printf '%s: INTEGRITY VIOLATION\n' "$(date)" >> "$LOG" 
    printf '%s\n' "$OUTPUT" >> "$LOG" 
fi
