#!/bin/ksh
# ==========================================================
#  dropQbsd -- run_app_impl
#
#  Launches graphical applications as a domain user with
#  X11 forwarding. The main user (conductor) invokes this
#  through a setuid wrapper (run_app) that escalates to root,
#  keeping the conductor's doas.conf clean of any privilege.
#
#  Two modes:
#    Normal:    isolated runtime directory under /tmp,
#               cleaned on exit.
#    Disposable: dedicated tmpfs mounted in RAM, destroyed
#               on exit. Nothing survives. Ideal for browsers
#               and untrusted files.
#
#  How it works:
#    1. Called by run_app (setuid C wrapper) as root.
#    2. Locates the X11 cookie from xenodm's auth directory
#       so the target user can connect to the display.
#    3. Creates an isolated runtime directory (tmpfs if
#       --disposable) owned by the target user. Uses
#       mktemp -d in ALL modes to prevent symlink attacks.
#    4. Launches the app via su -l with the correct
#       DISPLAY, XAUTHORITY, XDG_RUNTIME_DIR, and HOME.
#    5. On exit, cleans up the runtime directory (normal)
#       or unmounts and removes the tmpfs (disposable).
#
#  Security:
#    - No doas rules for the conductor user. The setuid
#      wrapper is the only path to root, and it runs only
#      this script -- nothing else.
#    - su -l switches to the target user without permanent
#      doas.conf rules for root to impersonate domains.
#    - Domain users (userdoc, usermail, userweb) remain
#      isolated from each other and from the conductor.
#    - All runtime directories use mktemp -d to prevent
#      symlink attacks -- no predictable paths.
#
#  Paths:
#    /opt/dropQbsd/bin/run_app       (setuid C wrapper)
#    /opt/dropQbsd/libexec/run_app_impl  (this script)
#  Permissions:
#    run_app:      4755 root:wheel
#    run_app_impl: 0755 root:wheel
#
#  Usage:
#    run_app [--disposable [size]] <target_user> <command> [args...]
#
#  Examples:
#    run_app userweb qutebrowser --temp-basedir https://qwant.com
#    run_app --disposable userweb ungoogled-chromium --temp-profile
#    run_app --disposable 1G userweb firefox --private-window
#    run_app --disposable 250M userweb mupdf /tmp/sketchy.pdf
#    run_app usermail claws-mail
#
#  Prerequisites:
#    - Target users (userweb, usermail, userdoc) must exist.
#    - doas.conf needs only:
#        permit nopass root
#    - xenodm must be running (standard on OpenBSD desktop).
# ==========================================================

#-----------------------------------------------------------------------------
# CONFIGURATION
#-----------------------------------------------------------------------------
AUTH_DIR="/etc/X11/xenodm/authdir/authfiles"
DEFAULT_DISPOSABLE_SIZE="500M"

#-----------------------------------------------------------------------------
# PARSE OPTIONAL --disposable FLAG
#-----------------------------------------------------------------------------
DISPOSABLE=0
DISPOSABLE_SIZE="$DEFAULT_DISPOSABLE_SIZE"

if [[ "$1" == "--disposable" ]]; then
    DISPOSABLE=1
    shift
    # Check if next argument is a custom size (e.g. 1G, 250M)
    if [[ "$1" == *M || "$1" == *G ]]; then
        DISPOSABLE_SIZE="$1"
        shift
    fi
fi

#-----------------------------------------------------------------------------
# ARGUMENT CHECK
#-----------------------------------------------------------------------------
if [[ $# -lt 2 ]]; then
    echo "Usage: $(basename $0) [--disposable [size]] <target_user> <command> [args...]"
    exit 1
fi

TARGET_USER=$1
APP_CMD=$2
shift 2


#-----------------------------------------------------------------------------
# VERIFY TARGET USER EXISTS
#-----------------------------------------------------------------------------
if ! id "$TARGET_USER" >/dev/null 2>&1; then
    echo "Error: User '$TARGET_USER' does not exist." >&2
    exit 1
fi

#-----------------------------------------------------------------------------
# ALLOWLIST: ONLY DOMAIN USERS PERMITTED
#-----------------------------------------------------------------------------
case "$TARGET_USER" in
    userweb|usermail|userdoc)
        ;;
    *)
        echo "Error: '$TARGET_USER' is not a valid domain user." >&2
        exit 1
        ;;
esac

#-----------------------------------------------------------------------------
# LOCATE X11 AUTHENTICATION COOKIE
#-----------------------------------------------------------------------------
# xenodm creates per-session cookies in AUTH_DIR named A:0-<random>.
# Grab the first match -- there should be exactly one per display.
# Note: OpenBSD find(1) does not support -quit. We use head -1 instead.
AUTH_SRC=$(find "$AUTH_DIR" -maxdepth 1 -name 'A:0-*' -print 2>/dev/null | head -1)



if [[ -z "$AUTH_SRC" ]]; then
    echo "Error: No X11 authentication file found in $AUTH_DIR" >&2
    exit 1
fi

#-----------------------------------------------------------------------------
# SET UP RUNTIME DIRECTORY
#-----------------------------------------------------------------------------
# ALWAYS use mktemp -d to prevent symlink attacks.
# In disposable mode the directory becomes a tmpfs mount point.
# In normal mode it's a plain directory under /tmp.
# Both are cleaned on exit.
if [[ "$DISPOSABLE" -eq 1 ]]; then
    RUNDIR=$(mktemp -d /tmp/disposable.XXXXXX)
    if ! mount -t mfs -o rw,nodev,nosuid,-s="$DISPOSABLE_SIZE" swap "$RUNDIR"; then
        echo "Error: Failed to mount tmpfs ($DISPOSABLE_SIZE). Not enough RAM?" >&2
        rmdir "$RUNDIR"
        exit 1
    fi
    chown "$TARGET_USER" "$RUNDIR"
    chmod 700 "$RUNDIR"
else
    RUNDIR=$(mktemp -d /tmp/runtime.XXXXXX)
    chown "$TARGET_USER" "$RUNDIR"
    chmod 700 "$RUNDIR"
fi

#-----------------------------------------------------------------------------
# COPY AND RESTRICT X11 COOKIE
#-----------------------------------------------------------------------------
AUTH_FILE="$RUNDIR/.Xauthority"
cp "$AUTH_SRC" "$AUTH_FILE"
chown "$TARGET_USER" "$AUTH_FILE"
chmod 600 "$AUTH_FILE"

#-----------------------------------------------------------------------------
# LAUNCH APPLICATION AS TARGET USER
#-----------------------------------------------------------------------------
# HOME is set to RUNDIR for disposable mode so the app writes everything
# inside the tmpfs -- destroyed on exit.
# For normal mode, HOME is the target user's real home directory.
if [[ "$DISPOSABLE" -eq 1 ]]; then
    APP_HOME="$RUNDIR"
else
    APP_HOME=$(eval echo ~"$TARGET_USER")
fi

# DOWNLOADS BRIDGE (disposable mode only)
# In disposable mode, HOME is a tmpfs that gets destroyed on exit.
# To preserve downloaded files, symlink ~/Downloads to the real
# /home/$TARGET_USER/Downloads so files survive browser close.
if [[ "$DISPOSABLE" -eq 1 ]]; then
    REAL_DOWNLOADS="/home/$TARGET_USER/Downloads"
    mkdir -p "$REAL_DOWNLOADS"
    chown "$TARGET_USER" "$REAL_DOWNLOADS"
    su -l "$TARGET_USER" -c "ln -sfn '$REAL_DOWNLOADS' '$RUNDIR/Downloads'"
fi

# Pass arguments via positional parameters to avoid quoting issues
# with $* inside a -c string.
su -l "$TARGET_USER" -c '
    export DISPLAY="$1"
    export XAUTHORITY="$2"
    export XDG_RUNTIME_DIR="$3"
    export HOME="$4"
    shift 4
    exec "$@"
' -- "$DISPLAY" "$AUTH_FILE" "$RUNDIR" "$APP_HOME" "$APP_CMD" "$@"

#-----------------------------------------------------------------------------
# CLEANUP
#-----------------------------------------------------------------------------
if [[ "$DISPOSABLE" -eq 1 ]]; then
    # Unmount the tmpfs -- all data written by the app is gone.
    umount "$RUNDIR" 2>/dev/null
    rmdir "$RUNDIR" 2>/dev/null
else
    rm -rf "$RUNDIR"
fi

